APP_ENV=local
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Riyadh
PORT=8000

# Comma-separated web client origins allowed to call the API with credentials.
# Leave empty to reflect any origin (dev only).
CORS_ALLOWED_ORIGINS=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=umrahservice_app
DB_USERNAME=root
DB_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=storage
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# Upstream Laravel app, used for delegated work like PIF PDF generation.
LARAVEL_URL=http://localhost
INTERNAL_API_SECRET=

# Filesystem path to Laravel's storage/app/public directory (shared volume).
# When set, file URLs resolve from local disk first before falling back to S3.
LARAVEL_STORAGE_PATH=

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
